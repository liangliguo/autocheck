# 复制为 `.env` 后再填写真实值。
# `.env` 只用于本地运行，不要提交到 Git。

# OpenAI 或兼容网关的 API Key。
OPENAI_API_KEY=
# OpenAI 兼容接口的基础地址，通常以 `/v1` 结尾。
AUTOCHECK_OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
# 单次请求超时时间，单位为秒。
AUTOCHECK_OPENAI_TIMEOUT=120
# 请求失败后的最大重试次数。
AUTOCHECK_OPENAI_MAX_RETRIES=2
# 与兼容接口通信时使用的协议，当前推荐 `responses`。
# 注意：此参数仅在使用 OpenAI 原生 API 时生效，第三方兼容 API 会自动忽略。
AUTOCHECK_OPENAI_WIRE_API=responses
# 是否禁止服务端存储响应，`true` 更适合隐私敏感场景。
# 注意：此参数仅在使用 OpenAI 原生 API 时生效。
AUTOCHECK_OPENAI_DISABLE_RESPONSE_STORAGE=true
# 推理强度配置，值越高通常越慢但推理更充分。
# 注意：此参数仅在使用 OpenAI 原生 API 时生效。
AUTOCHECK_MODEL_REASONING_EFFORT=
# 是否启用 Qwen/百炼兼容接口的深度思考。
# 注意：此参数仅在使用第三方 OpenAI 兼容 API 时通过 extra_body 传递。
AUTOCHECK_ENABLE_THINKING=false
# Qwen 思考预算；设为 0 表示不传该参数。
AUTOCHECK_THINKING_BUDGET=0
# 是否保留多轮思考上下文。
AUTOCHECK_PRESERVE_THINKING=false
# 是否启用 LLM 参与声明与参考文献抽取，真实论文通常建议关闭。
AUTOCHECK_ENABLE_LLM_EXTRACTION=false
# 是否启用 LLM 参与引用核验，通常建议保持开启。
AUTOCHECK_ENABLE_LLM_VERIFICATION=true
# 默认聊天模型；提取和核验模型未单独指定时会回退到这里。
AUTOCHECK_CHAT_MODEL=qwen3-max
# 抽取阶段专用模型；留空时回退到 `AUTOCHECK_CHAT_MODEL`。
AUTOCHECK_EXTRACT_MODEL=
# 核验阶段专用模型；通常与聊天模型保持一致。
AUTOCHECK_VERIFY_MODEL=qwen3-max
# 采样温度；`0` 表示结果更稳定、更可复现。
AUTOCHECK_TEMPERATURE=0
# 检索证据时的切块大小，单位为字符。
AUTOCHECK_CHUNK_SIZE=2200
# 相邻证据块之间的重叠字符数。
AUTOCHECK_CHUNK_OVERLAP=300
# 结构化输出方法：`function_calling`（默认）或 `json_mode`（部分第三方 API 更兼容）。
AUTOCHECK_STRUCTURED_OUTPUT_METHOD=function_calling
# Sci-Hub 镜像地址：自定义 Sci-Hub 网址，留空则使用默认镜像列表。
# 示例：https://sci-hub.se 或 https://sci-hub.st
AUTOCHECK_SCIHUB_URL=
